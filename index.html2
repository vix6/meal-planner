<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>What are we eating this week? 🍽️</title>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --b-hdr: #BA7517; --b-light: #FAEEDA;
    --l-hdr: #3B6D11; --l-light: #EAF3DE;
    --d-hdr: #185FA5; --d-light: #E6F1FB;
    --s-hdr: #534AB7; --s-light: #EEEDFE;
    --n-hdr: #5F5E5A; --n-light: #F1EFE8;
    --bg: #FAF9F7; --text: #1a1a18; --muted: #888780;
    --card-bg: #ffffff; --border: rgba(0,0,0,0.08);
  }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }

  .hero {
    background: #1a1a18; color: white;
    padding: 3rem 2rem 2.5rem; text-align: center;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at 20% 50%, rgba(186,117,23,0.25) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 20%, rgba(24,95,165,0.2) 0%, transparent 55%),
                radial-gradient(ellipse at 60% 80%, rgba(83,74,183,0.18) 0%, transparent 50%);
    pointer-events: none;
  }
  .hero h1 { font-family: Georgia, 'Times New Roman', serif; font-size: clamp(1.8rem,6vw,3rem); font-weight: 600; position: relative; margin-bottom: 0.4rem; }
  .hero p { font-size: 0.9rem; color: rgba(255,255,255,0.5); font-weight: 300; position: relative; }

  .summary-strip {
    background: #1a1a18; border-top: 1px solid rgba(255,255,255,0.08);
    padding: 0.9rem 1.5rem; display: flex; align-items: center; justify-content: space-between;
    gap: 1rem; flex-wrap: wrap; position: sticky; top: 0; z-index: 100;
  }
  .picked-chips { display: flex; flex-wrap: wrap; gap: 6px; flex: 1; min-width: 0; }
  .chip {
    font-size: 12px; padding: 4px 12px; border-radius: 20px; color: white; font-weight: 500;
    animation: popIn 0.2s cubic-bezier(0.34,1.56,0.64,1); white-space: nowrap;
  }
  @keyframes popIn { from { transform: scale(0.7); opacity: 0; } to { transform: scale(1); opacity: 1; } }
  .empty-hint { font-size: 13px; color: rgba(255,255,255,0.35); font-weight: 300; }
  .strip-actions { display: flex; gap: 8px; flex-shrink: 0; }
  .strip-btn {
    font-family: inherit; font-size: 12px; padding: 5px 14px;
    border: 1px solid rgba(255,255,255,0.2); border-radius: 20px;
    background: transparent; color: rgba(255,255,255,0.55); cursor: pointer;
    transition: all 0.15s; white-space: nowrap;
  }
  .strip-btn:hover { background: rgba(255,255,255,0.08); color: white; }
  .wa-btn {
    font-family: inherit; font-size: 13px; font-weight: 500;
    padding: 7px 18px; border: none; border-radius: 20px;
    background: #25D366; color: white; cursor: pointer; transition: all 0.15s;
    display: flex; align-items: center; gap: 7px; white-space: nowrap;
    opacity: 0.4; pointer-events: none;
  }
  .wa-btn.active { opacity: 1; pointer-events: auto; }
  .wa-btn.active:hover { background: #1ebe5d; transform: translateY(-1px); }
  .wa-icon { width: 16px; height: 16px; fill: white; flex-shrink: 0; }

  .content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem 5rem; }
  .section { margin-bottom: 2.5rem; }
  .section-label {
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 1rem; cursor: pointer; user-select: none;
  }
  .section-label h2 { font-family: Georgia, 'Times New Roman', serif; font-size: 1.4rem; font-weight: 600; }
  .section-label .pill { font-size: 11px; font-weight: 500; padding: 3px 10px; border-radius: 20px; color: white; margin-left: auto; }
  .section-label .chev { font-size: 11px; color: var(--muted); transition: transform 0.2s; }
  .section-label.open .chev { transform: rotate(90deg); }

  .subsection { margin-bottom: 1rem; }
  .sub-label { font-size: 11px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.6rem; padding-left: 2px; }
  .tags { display: flex; flex-wrap: wrap; gap: 8px; }
  .tag {
    padding: 8px 16px; border-radius: 30px; font-size: 13px;
    cursor: pointer; border: 1.5px solid var(--border);
    transition: all 0.15s cubic-bezier(0.4,0,0.2,1);
    background: var(--card-bg); color: var(--text);
    display: flex; align-items: center; gap: 6px;
  }
  .tag:hover { transform: translateY(-1px); box-shadow: 0 3px 10px rgba(0,0,0,0.08); }
  .tag.on { color: white; border-color: transparent; }
  .tag.on::after { content: '✓'; font-size: 11px; opacity: 0.85; }

  .t-breakfast .tag.on { background: var(--b-hdr); }
  .t-breakfast .section-label h2 { color: var(--b-hdr); }
  .t-breakfast .pill { background: var(--b-hdr); }
  .t-lunch .tag.on { background: var(--l-hdr); }
  .t-lunch .section-label h2 { color: var(--l-hdr); }
  .t-lunch .pill { background: var(--l-hdr); }
  .t-dinner .tag.on { background: var(--d-hdr); }
  .t-dinner .section-label h2 { color: var(--d-hdr); }
  .t-dinner .pill { background: var(--d-hdr); }
  .t-snacks .tag.on { background: var(--s-hdr); }
  .t-snacks .section-label h2 { color: var(--s-hdr); }
  .t-snacks .pill { background: var(--s-hdr); }

  .add-row { display: flex; gap: 8px; margin-top: 10px; }
  .add-input {
    flex: 1; font-family: inherit; font-size: 13px; padding: 8px 14px;
    border: 1.5px solid var(--border); border-radius: 30px;
    background: var(--card-bg); color: var(--text); outline: none; transition: border-color 0.15s;
  }
  .add-input:focus { border-color: rgba(0,0,0,0.25); }
  .add-btn {
    font-family: inherit; font-size: 13px; padding: 8px 16px;
    border: 1.5px solid var(--border); border-radius: 30px;
    background: transparent; color: var(--muted); cursor: pointer; transition: all 0.15s;
  }
  .add-btn:hover { background: var(--card-bg); color: var(--text); }

  /* Notes section */
  .notes-section { margin-bottom: 2.5rem; }
  .notes-section .section-label h2 { color: var(--n-hdr); }
  .notes-section .pill { background: var(--n-hdr); }
  .notes-hint {
    font-size: 13px; color: var(--muted); margin-bottom: 12px; line-height: 1.6;
  }
  .notes-grid { display: flex; flex-direction: column; gap: 10px; }
  .note-row {
    background: var(--card-bg); border: 1.5px solid var(--border);
    border-radius: 12px; padding: 12px 14px;
    display: flex; flex-direction: column; gap: 6px;
  }
  .note-row-label {
    font-size: 11px; font-weight: 500; letter-spacing: 0.07em;
    text-transform: uppercase; color: var(--muted);
  }
  .note-textarea {
    font-family: inherit; font-size: 13px; color: var(--text);
    border: none; outline: none; background: transparent;
    resize: none; width: 100%; line-height: 1.6;
    min-height: 36px;
  }
  .note-textarea::placeholder { color: #B4B2A9; }

  .divider { height: 1px; background: var(--border); margin: 2rem 0; }
  footer { text-align: center; padding: 2rem; font-size: 12px; color: var(--muted); font-weight: 300; }

  @media (max-width: 600px) {
    .hero { padding: 2rem 1.25rem 1.75rem; }
    .content { padding: 1.5rem 1rem 3rem; }
    .summary-strip { padding: 0.75rem 1rem; }
  }
</style>
</head>
<body>

<div class="hero">
  <h1>What are we eating? 🍽️</h1>
  <p>Pick your meals for the week, then send to Vicky</p>
</div>

<div class="summary-strip">
  <div class="picked-chips" id="chips">
    <span class="empty-hint">Nothing picked yet</span>
  </div>
  <div class="strip-actions">
    <button class="strip-btn" onclick="clearAll()">Clear</button>
    <button class="wa-btn" id="wa-btn" onclick="sendWhatsApp()">
      <svg class="wa-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      Send to Vicky
    </button>
  </div>
</div>

<div class="content" id="app"></div>
<footer>Pick your meals above, then hit "Send to Vicky" 💚</footer>

<script>
const WA_NUMBER = '447462609799';

const DATA = {
  breakfast: {
    label: 'Breakfast', theme: 't-breakfast', chipColor: '#BA7517',
    sections: { '': ["Overnight oats","Baked oats","Granola & Greek yoghurt","Fruit & Greek yoghurt","Breakfast sandwiches","Pancake bowls","McDonalds cheesy bacon flatbread fakeaway"] }
  },
  lunch: {
    label: 'Lunch', theme: 't-lunch', chipColor: '#3B6D11',
    sections: { '': ["Ham & cheese sandwiches","Ham & cheese bagels"] }
  },
  dinner: {
    label: 'Dinner', theme: 't-dinner', chipColor: '#185FA5',
    sections: {
      'Chicken': ["Chinese chicken curry","Chicken pie","Chicken fajitas","Chicken tikka and rice","Teriyaki chicken stir fry","Chicken traybake","Chicken pesto pasta","Tomato chicken pasta","Chicken burgers","Chicken gyros","Chicken salad","Burrito bowl","Nandos chicken bowl","Nandos chicken thigh burgers"],
      'Beef & Pork': ["Meatballs","Burgers","Beef tacos","Steak and chips","Steak and mash","Steak pie","Caramelised onion sausage pasta","Sausage and mash","Toad in the hole","Bacon and cheese jacket potatoes","Meatball orzo"],
      'Fish': ["Fish finger sandwiches"],
      'Other': ["Omelette","Halloumi burgers"]
    }
  },
  snacks: {
    label: 'Snacks', theme: 't-snacks', chipColor: '#534AB7',
    sections: { '': ["Rice cakes","Apple & peanut butter","Fruit","Yoghurt","Banana","Dark chocolate","Crisps","Protein bar","Breakfast bar"] }
  }
};

const NOTE_FIELDS = [
  { id: 'note-sides',   label: 'Sides & preferences', placeholder: 'e.g. chips with the steak, extra sauce on the fajitas...' },
  { id: 'note-swaps',   label: 'Swaps or alternatives', placeholder: 'e.g. swap the chicken tikka for the gyros on Thursday...' },
  { id: 'note-general', label: 'Anything else', placeholder: 'e.g. not feeling the fish this week, can we do a takeaway Friday?' },
];

let picked = [];
let collapsed = {};

function toggle(meal) {
  const i = picked.indexOf(meal);
  i === -1 ? picked.push(meal) : picked.splice(i, 1);
  render();
}
function clearAll() {
  picked = [];
  NOTE_FIELDS.forEach(f => { const el = document.getElementById(f.id); if (el) el.value = ''; });
  render();
}
function toggleSection(key) { collapsed[key] = !collapsed[key]; render(); }

function addMeal(key, sub, inputId) {
  const el = document.getElementById(inputId);
  const v = el.value.trim();
  if (!v) return;
  if (!DATA[key].sections[sub].includes(v)) DATA[key].sections[sub].push(v);
  el.value = '';
  render();
}

function getNotes() {
  return NOTE_FIELDS.map(f => {
    const el = document.getElementById(f.id);
    return el ? { label: f.label, value: el.value.trim() } : null;
  }).filter(n => n && n.value);
}

function sendWhatsApp() {
  if (!picked.length) return;
  const sections = {};
  for (const d of Object.values(DATA)) sections[d.label] = [];
  picked.forEach(m => {
    for (const d of Object.values(DATA)) {
      for (const meals of Object.values(d.sections)) {
        if (meals.includes(m)) { sections[d.label].push(m); return; }
      }
    }
  });

  const weekStr = new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
  let msg = `Hey! Here are my meal picks for the week of ${weekStr} 🍽️\n\n`;
  for (const [label, items] of Object.entries(sections)) {
    if (items.length) {
      msg += `*${label}*\n`;
      items.forEach(i => msg += `• ${i}\n`);
      msg += '\n';
    }
  }

  const notes = getNotes();
  if (notes.length) {
    msg += `*Notes*\n`;
    notes.forEach(n => msg += `📝 ${n.label}: ${n.value}\n`);
    msg += '\n';
  }

  msg += 'Sound good? 😊';
  window.open(`https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(msg)}`, '_blank');
}

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = el.scrollHeight + 'px';
}

function render() {
  // preserve note values before re-render
  const savedNotes = {};
  NOTE_FIELDS.forEach(f => {
    const el = document.getElementById(f.id);
    if (el) savedNotes[f.id] = el.value;
  });

  // chips + WA button
  const chips = document.getElementById('chips');
  const waBtn = document.getElementById('wa-btn');
  if (!picked.length) {
    chips.innerHTML = '<span class="empty-hint">Nothing picked yet</span>';
    waBtn.classList.remove('active');
  } else {
    chips.innerHTML = picked.map(m => {
      let col = '#888';
      for (const d of Object.values(DATA)) {
        for (const meals of Object.values(d.sections)) {
          if (meals.includes(m)) { col = d.chipColor; break; }
        }
      }
      return `<span class="chip" style="background:${col}">${m}</span>`;
    }).join('');
    waBtn.classList.add('active');
  }

  // meal sections
  const app = document.getElementById('app');
  let html = '';
  const keys = Object.keys(DATA);
  keys.forEach((key, idx) => {
    const d = DATA[key];
    const isOpen = !collapsed[key];
    const total = Object.values(d.sections).flat().length;
    html += `<div class="section ${d.theme}">
      <div class="section-label ${isOpen ? 'open' : ''}" onclick="toggleSection('${key}')">
        <h2>${d.label}</h2>
        <span class="pill">${total}</span>
        <span class="chev">▶</span>
      </div>`;
    if (isOpen) {
      for (const [sub, meals] of Object.entries(d.sections)) {
        const iid = `inp-${key}-${sub.replace(/\s/g,'_') || 'main'}`;
        html += `<div class="subsection">`;
        if (sub) html += `<div class="sub-label">${sub}</div>`;
        html += `<div class="tags">`;
        meals.forEach(m => {
          const on = picked.includes(m);
          html += `<div class="tag ${on?'on':''}" onclick="toggle('${m.replace(/'/g,"\\'")}')"> ${m}</div>`;
        });
        html += `</div><div class="add-row">
          <input class="add-input" id="${iid}" placeholder="Add a meal..." onkeydown="if(event.key==='Enter')addMeal('${key}','${sub}','${iid}')">
          <button class="add-btn" onclick="addMeal('${key}','${sub}','${iid}')">+ Add</button>
        </div></div>`;
      }
    }
    html += `</div><div class="divider"></div>`;
  });

  // notes section
  html += `<div class="notes-section">
    <div class="section-label open" onclick="toggleSection('__notes__')">
      <h2>Notes</h2>
      <span class="pill" style="background:var(--n-hdr)">optional</span>
      <span class="chev ${!collapsed['__notes__'] ? '' : ''}" style="font-size:11px;color:var(--muted);transition:transform 0.2s;${collapsed['__notes__']?'':'transform:rotate(90deg)'}">▶</span>
    </div>`;

  if (!collapsed['__notes__']) {
    html += `<p class="notes-hint">Anything Vicky should know — preferred sides, swaps, requests, or just a heads up.</p>
    <div class="notes-grid">`;
    NOTE_FIELDS.forEach(f => {
      const saved = savedNotes[f.id] || '';
      html += `<div class="note-row">
        <div class="note-row-label">${f.label}</div>
        <textarea class="note-textarea" id="${f.id}" placeholder="${f.placeholder}" rows="1" oninput="autoResize(this)">${saved}</textarea>
      </div>`;
    });
    html += `</div>`;
  }
  html += `</div>`;

  app.innerHTML = html;

  // restore heights
  NOTE_FIELDS.forEach(f => {
    const el = document.getElementById(f.id);
    if (el && el.value) autoResize(el);
  });
}

render();
</script>
</body>
</html>
